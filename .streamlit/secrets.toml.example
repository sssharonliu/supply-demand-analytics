# .streamlit/secrets.toml
# ────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your credentials.
# secrets.toml is gitignored — never commit it.
#
# On Streamlit Community Cloud, paste these key/value pairs into:
#   App Settings → Secrets
# (same format, no need to create the file on the server)

DB_USER     = "root"
DB_PASSWORD = "your_mysql_password"
DB_HOST     = "localhost"
DB_NAME     = "supply_chain_db"
